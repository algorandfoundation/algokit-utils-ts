{
  "$schema": "https://typedoc.org/schema.json",
  "jsDocCompatibility": {
    "exampleTag": false
  },
  "entryPoints": [
    "src/index.ts",
    "src/abi/index.ts",
    "src/algo25/index.ts",
    "src/transact/index.ts",
    "src/algod-client/index.ts",
    "src/indexer-client/index.ts",
    "src/kmd-client/index.ts",
    "src/testing/index.ts"
  ],
  "entryPointStrategy": "expand",
  "exclude": ["src/**/*.spec.ts", "tests/**/*.*", "examples/**/*.*"],
  "out": "docs/_html",
  "tsconfig": "tsconfig.build.json",
  "readme": "docs/guides/README.md",
  "projectDocuments": ["docs/guides/Concepts/*.md", "docs/guides/Migration/*.md"],
  "gitRevision": "main",
  "cleanOutputDir": true,
  "excludeReferences": true,
  "includeHierarchySummary": true,
  "highlightLanguages": ["typescript", "python", "json", "bash", "javascript", "yaml"]
}
