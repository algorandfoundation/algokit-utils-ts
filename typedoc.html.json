{
  "$schema": "https://typedoc.org/schema.json",
  "jsDocCompatibility": {
    "exampleTag": false
  },
  "entryPoints": [
    "src/index.ts",
    "src/types/*.ts",
    "src/abi/index.ts",
    "src/algo25/index.ts",
    "src/transact/index.ts",
    "src/transaction/index.ts",
    "src/algod-client/index.ts",
    "src/indexer-client/index.ts",
    "src/kmd-client/index.ts",
    "src/testing/index.ts",
    "src/types/*.ts"
  ],
  "navigationLinks": {
    "Examples": "/examples/",
    "GitHub": "https://github.com/your-username/your-repo"
  },
  "entryPointStrategy": "expand",
  "exclude": ["src/**/*.spec.ts", "tests/**/*.*"],
  "out": "docs",
  "tsconfig": "tsconfig.build.json",
  "readme": "README.md",
  "projectDocuments": [],
  "gitRevision": "main",
  "cleanOutputDir": false,
  "excludeReferences": true,
  "includeHierarchySummary": true,
  "highlightLanguages": ["typescript", "python", "json", "bash", "javascript", "yaml"]
}
