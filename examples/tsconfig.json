{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@algorandfoundation/algokit-utils": ["../src/index.ts"],
      "@algorandfoundation/algokit-utils/types/*": ["../src/types/*"],
      "@algorandfoundation/algokit-utils/abi": ["../packages/abi/src/index.ts"],
      "@algorandfoundation/algokit-utils/algo25": ["../packages/algo25/src/index.ts"],
      "@algorandfoundation/algokit-utils/algod-client": ["../packages/algod_client/src/index.ts"],
      "@algorandfoundation/algokit-utils/common": ["../packages/common/src/index.ts"],
      "@algorandfoundation/algokit-utils/indexer-client": ["../packages/indexer_client/src/index.ts"],
      "@algorandfoundation/algokit-utils/kmd-client": ["../packages/kmd_client/src/index.ts"],
      "@algorandfoundation/algokit-utils/testing": ["../packages/testing/src/index.ts"],
      "@algorandfoundation/algokit-utils/transact": ["../packages/transact/src/index.ts"]
    },
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}
