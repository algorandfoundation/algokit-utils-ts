#pragma version 10
txn ApplicationID
bz create
// On call: increment counter
byte "counter"
app_global_get
int 1
+
byte "counter"
swap
app_global_put
byte "message"
byte "Hello, Algorand!"
app_global_put
int 1
return
create:
