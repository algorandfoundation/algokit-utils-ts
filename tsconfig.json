{
  "extends": "@tsconfig/node20/tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES2022",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "lib": ["ES2022", "dom"],
    "types": ["node"],
    "outDir": "dist",
    "declaration": true,
    "importHelpers": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@algorandfoundation/algokit-utils": ["./src/index.ts"],
      "@algorandfoundation/algokit-utils/abi": ["./src/abi/index.ts"],
      "@algorandfoundation/algokit-utils/transact": ["./src/transact/index.ts"],
      "@algorandfoundation/algokit-utils/algod-client": ["./src/algod-client/index.ts"],
      "@algorandfoundation/algokit-utils/indexer-client": ["./src/indexer-client/index.ts"],
      "@algorandfoundation/algokit-utils/kmd-client": ["./src/kmd-client/index.ts"],
      "@algorandfoundation/algokit-utils/algo25": ["./src/algo25/index.ts"],
      "@algorandfoundation/algokit-utils/types/*": ["./src/types/*"],
      "@algorandfoundation/algokit-common": ["./packages/common/src"],
      "@algorandfoundation/algokit-transact": ["./packages/transact/src"],
      "@algorandfoundation/algokit-abi": ["./packages/abi/src"],
      "@algorandfoundation/algokit-algod-client": ["./packages/algod_client/src"],
      "@algorandfoundation/algokit-indexer-client": ["./packages/indexer_client/src"],
      "@algorandfoundation/algokit-kmd-client": ["./packages/kmd_client/src"],
      "@algorandfoundation/algokit-algo25": ["./packages/algo25/src"]
    }
  },
  "include": ["src/**/*.ts", "tests/**/*.ts", "examples/**/*.ts"],
  "exclude": ["**/*.algo.ts"]
}
