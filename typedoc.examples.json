{
  "$schema": "https://typedoc.org/schema.json",
  "name": "AlgoKit Utils - Examples",
  "entryPoints": ["examples/**/*.ts", "src/types/**/*.ts", "src/transaction/**/*.ts", "src/testing/**/*.ts"],
  "entryPointStrategy": "expand",
  "out": "docs/_examples",
  "tsconfig": "tsconfig.json",
  "projectDocuments": ["examples/README.md"],
  "navigationLinks": {
    "API Docs": "./../api/index.html"
  },
  "cleanOutputDir": true,
  "excludeReferences": false,
  "readme": "examples/README.md",
  "gitRevision": "main",
  "highlightLanguages": ["typescript", "bash", "js"]
}
